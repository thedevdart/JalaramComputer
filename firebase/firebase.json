{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "../public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/", "destination": "/index.html" },
      { "source": "/shop", "destination": "/shop.html" },
      { "source": "/product", "destination": "/product.html" },
      { "source": "/cart", "destination": "/cart.html" },
      { "source": "/checkout", "destination": "/checkout.html" },
      { "source": "/order-confirmed", "destination": "/order-confirmed.html" },
      { "source": "/services", "destination": "/services.html" },
      { "source": "/about", "destination": "/about.html" },
      { "source": "/contact", "destination": "/contact.html" },
      { "source": "/account", "destination": "/account.html" },
      { "source": "/admin", "destination": "/admin.html" },
      { "source": "/book-service", "destination": "/book-service.html" }
    ],
    "headers": [
      {
        "source": "/assets/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.@(html)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache" }
        ]
      },
      {
        "source": "**",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
        ]
      }
    ]
  }
}
